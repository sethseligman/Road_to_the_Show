# Optional: AI narrator (Haiku). If unset, templates are used.
# Local dev: copy this file to `.env.local` in this folder, or start from
# `env.local.template` (same content, easier to spot in the file tree).
ANTHROPIC_API_KEY=

# Optional: KV cache for narrate responses (@vercel/kv)
KV_REST_API_URL=
KV_REST_API_TOKEN=
